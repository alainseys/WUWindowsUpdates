   <View>
      <Name>DefaulAddonView</Name>
      <ViewSelectedBy>
        <TypeName>VMware.ImageBuilder.Types.Addon</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>Name</Label>
                <ScriptBlock>$_.Namespec.Name</ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Name UI</Label>
                <ScriptBlock>$_.Namespec.Uistring</ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Version</Label>
                <ScriptBlock>$_.versionSpec.Version</ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Version UI</Label>
                <ScriptBlock>$_.versionSpec.Uistring</ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Vendor</Label>
                <PropertyName>vendor</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Category</Label>
                <PropertyName>category</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Summary</Label>
                <PropertyName>summary</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Description</Label>
                <PropertyName>description</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Release date</Label>
                <PropertyName>releaseDate</PropertyName>
                <FormatString>{0:MM/dd/yyy HH:mm:ss}</FormatString>
              </ListItem>
              <ListItem>
                <Label>KB url</Label>
                <PropertyName>docURL</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Components</Label>
                  <ScriptBlock>
                     $components = @()
                     foreach ($component in $_.components) {
                        $components += $component.Name + ":" + $component.Version
                     }

                     $components -join ", "
                  </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Removed components</Label>
                <ScriptBlock>$_.RemovedComponents -join ", "</ScriptBlock>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

