   <View>
      <Name>DefaulBulletinView</Name>
      <ViewSelectedBy>
        <TypeName>VMware.ImageBuilder.Types.Bulletin</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
